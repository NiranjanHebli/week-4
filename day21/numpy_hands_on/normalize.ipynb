   "source": [
    "import numpy as np\n",
    "\n",
    "def normalize(X):\n",
    "    return (X - np.min(X)) / (np.max(X) - np.min(X))\n",
    "\n",
    "X = np.array([10, 20, 30, 40, 50])\n",
    "print(normalize(X))"
   ]
  }
